# Enterprise Invoice Reconciler — backend env template.
# Copy to `.env` and fill in secrets. `.env` is gitignored.
# Used by api-gateway and ai-worker via docker-compose `env_file`.

# --- LLM provider ---
# Production default: Gemini Enterprise / Vertex AI via GCP IAM.
# Local auth options:
# 1. Host-local runs: `gcloud auth application-default login`
# 2. Docker Compose dev: copy a service-account JSON to `secrets/gcp-vertex-sa.json`
#    and run `make up-build-vertex` / `make dev-vertex`.
LLM_PROVIDER=vertex_ai
VERTEXAI_PROJECT=
VERTEXAI_LOCATION=europe-west4
# Optional model overrides. Defaults are provider-aware:
#   vertex_ai -> vertex_ai/gemini-2.5-flash for both primary and fast paths
#   api_keys  -> best available legacy model based on populated API keys
# PRIMARY_LLM_MODEL=vertex_ai/gemini-2.5-flash
# FAST_LLM_MODEL=vertex_ai/gemini-2.5-flash
# Set only when running outside the provided Docker Compose Vertex override.
# The override already sets this container path for ai-worker.
# GOOGLE_APPLICATION_CREDENTIALS=/var/secrets/google/gcp-vertex-sa.json

# Legacy / fallback API-key providers (only used when LLM_PROVIDER=api_keys)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Langfuse (self-hosted, docker-compose runs it on port 3030) ---
# Generate LANGFUSE_PUBLIC_KEY / LANGFUSE_SECRET_KEY in the Langfuse UI
# (http://localhost:3030) after the stack is up for the first time,
# then paste them here and restart api-gateway + ai-worker.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=http://localhost:3030

# Container-side secrets — generate each with: openssl rand -hex 32
# Changing these AFTER Langfuse has created data invalidates existing
# sessions and encrypted API keys. Set once, keep stable.
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_SALT=
LANGFUSE_ENCRYPTION_KEY=

# --- Optional Langfuse internals (docker-compose has safe defaults) ---
# LANGFUSE_MINIO_ROOT_PASSWORD=
# LANGFUSE_REDIS_AUTH=
# LANGFUSE_CLICKHOUSE_USER=
# LANGFUSE_CLICKHOUSE_PASSWORD=

# --- Temporal (overridden per-service in docker-compose) ---
TEMPORAL_ADDRESS=temporal:7233
